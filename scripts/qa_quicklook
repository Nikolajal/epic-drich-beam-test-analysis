#!/usr/bin/env bash
#
# Quick Local QA — single-entry launcher.
#
# First invocation creates `.venv/`, installs
# `qa_quicklook/requirements.txt`, runs the unit-test suite, then
# launches the GUI.  Subsequent invocations skip straight to the GUI
# unless an explicit mode flag is passed.
#
# Usage::
#
#     ./scripts/qa_quicklook              # bootstrap + launch GUI
#     ./scripts/qa_quicklook --setup      # bootstrap only, do not launch
#     ./scripts/qa_quicklook --test       # run the unit-test suite
#     ./scripts/qa_quicklook --reinstall  # rebuild .venv from scratch
#     ./scripts/qa_quicklook --help       # this help
#
# Any extra arguments after the mode flag are forwarded to the
# underlying Python invocation, so e.g.
#     ./scripts/qa_quicklook --repo-root /alt/path
# works for the GUI.

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

VENV=".venv"
REQS="qa_quicklook/requirements.txt"
PYTHON_BIN="$VENV/bin/python"

# ---------------------------------------------------------------------------
# Mode parsing — peel one optional flag off the front.
# ---------------------------------------------------------------------------

mode="gui"
if [[ $# -gt 0 ]]; then
    case "$1" in
        --setup)      mode="setup";      shift ;;
        --test)       mode="test";       shift ;;
        --reinstall)  mode="reinstall";  shift ;;
        -h|--help)
            sed -n '3,22p' "${BASH_SOURCE[0]}" | sed 's|^#\s\?||'
            exit 0
            ;;
    esac
fi

# ---------------------------------------------------------------------------
# Bootstrap helpers
# ---------------------------------------------------------------------------

log_step() { printf '\033[1;36m▸\033[0m %s\n' "$*"; }
log_ok()   { printf '\033[1;32m✓\033[0m %s\n' "$*"; }
log_warn() { printf '\033[1;33m!\033[0m %s\n' "$*" >&2; }
log_err()  { printf '\033[1;31m✗\033[0m %s\n' "$*" >&2; }

require_python3() {
    if ! command -v python3 >/dev/null 2>&1; then
        log_err "python3 not on PATH — install Python 3.11+ first."
        exit 1
    fi
    local ver
    ver="$(python3 -c 'import sys; print("%d.%d" % sys.version_info[:2])')"
    case "$ver" in
        3.1[1-9]|3.[2-9][0-9])  # 3.11+
            ;;
        *)
            log_warn "python3 is $ver — qa_quicklook expects 3.11+; tomllib + PySide6 may not behave."
            ;;
    esac
}

bootstrap_venv() {
    require_python3

    if [[ -d "$VENV" && "${1:-}" != "--force" ]]; then
        log_ok ".venv already present, skipping create"
    else
        if [[ -d "$VENV" ]]; then
            log_step "removing existing $VENV (--reinstall)"
            rm -rf "$VENV"
        fi
        log_step "creating $VENV"
        python3 -m venv "$VENV"
    fi

    log_step "upgrading pip"
    "$VENV/bin/pip" install --quiet --upgrade pip

    log_step "installing requirements from $REQS"
    "$VENV/bin/pip" install --quiet -r "$REQS"

    log_ok "venv ready: $VENV"
}

run_tests() {
    log_step "running unit tests"
    if "$PYTHON_BIN" -m unittest discover -s tests -q 2>&1 | tail -5; then
        log_ok "tests pass"
    else
        log_err "tests failed — see output above"
        return 1
    fi
}

ensure_ready() {
    if [[ ! -x "$PYTHON_BIN" ]]; then
        log_step "first-time setup — no $VENV detected"
        bootstrap_venv
        run_tests
        echo
    fi
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

case "$mode" in
    setup)
        bootstrap_venv
        run_tests
        echo
        log_ok "setup complete — next:  ./scripts/qa_quicklook"
        ;;

    reinstall)
        bootstrap_venv --force
        run_tests
        echo
        log_ok "reinstall complete"
        ;;

    test)
        ensure_ready
        exec "$PYTHON_BIN" -m unittest discover -s tests "$@"
        ;;

    gui)
        ensure_ready
        exec "$PYTHON_BIN" -m qa_quicklook.app "$@"
        ;;

    *)
        log_err "unknown mode: $mode"
        exit 1
        ;;
esac
