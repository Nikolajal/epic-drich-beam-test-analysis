#pragma once

//  Teach cling where the project's headers + libraries live so macros
//  can do `#include "util/root_io.h"` (and friends) and trigger ROOT's
//  autoloading of project classes without absolute paths.
//
//  Two flavours of this loader are generated by the build:
//
//    DEV-MODE (`macros/lib_loader.h`)
//      Used by macros run directly out of the source tree, before
//      `cmake --install`.  Points at:
//        @BEAM_LOADER_INCLUDE_DEV@  (source headers)
//        @BEAM_LOADER_LIB_DEV@      (build-tree library)
//
//    INSTALL-MODE (`<prefix>/include/lib_loader.h`)
//      Used by macros run against the installed framework.  Points
//      at the install prefix only.
//
//  R__ADD_INCLUDE_PATH expands to `#pragma cling add_include_path("…")`.
//
//  Why this single loader holds BOTH flavours but only ONE is active:
//  the dict payload embedded in `libbeam_test_analysis.dylib` carries
//  absolute paths to the source-tree headers (that's how
//  `ROOT_GENERATE_DICTIONARY` resolves the headers it was passed at
//  build time).  If the macro's `#include` search also has the
//  install-tree headers in scope, ROOT parses the same logical header
//  from two physical paths and triggers redefinitions for every type
//  the dict autoloads.  Pinning the macro to whichever path matches
//  the dict payload sidesteps the duplication.

#include "Rtypes.h"
R__ADD_INCLUDE_PATH(@BEAM_LOADER_INCLUDE@)

#pragma cling load("@BEAM_LOADER_LIB@")
