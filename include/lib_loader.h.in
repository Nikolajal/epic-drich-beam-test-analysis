#pragma once

// Teach cling where the project's installed headers live so macros can do
// #include "util/root_io.h" and friends without specifying absolute paths.
// R__ADD_INCLUDE_PATH expands to #pragma cling add_include_path("...").
#include "Rtypes.h"
R__ADD_INCLUDE_PATH(@CMAKE_INSTALL_PREFIX@/include)

// Load dynamic libraries (CMake will replace placeholders)
#pragma cling load("@BEAM_MAIN_LIB@")